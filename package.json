{
  "name": "ao-starter",
  "version": "0.1.0",
  "description": "CLI tool to scaffold AO workflows for any project",
  "type": "module",
  "bin": {
    "create-ao": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "ao",
    "cli",
    "scaffold",
    "workflow",
    "agent-orchestrator"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.10",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/launchapp-dev/ao-starter.git"
  },
  "bugs": {
    "url": "https://github.com/launchapp-dev/ao-starter/issues"
  },
  "homepage": "https://github.com/launchapp-dev/ao-starter#readme"
}

# AO Deno Agents Configuration
# Generated by ao-starter for Deno projects
# Generated: {{timestamp}}

agents:
{{#if agents}}
{{#each agents}}
  {{@key}}:
    role: {{this.role}}
    model: {{this.model}}
{{#if this.capabilities}}
    capabilities:
{{#each this.capabilities}}
      - {{this}}
{{/each}}
{{/if}}
    max_concurrent: {{this.max_concurrent}}
{{/each}}
{{else}}
  # Deno backend developer
  deno-developer:
    role: Deno Backend Developer
    model: claude-3-opus
    capabilities:
      - deno-development
      - typescript
      - web-apis
      - server-side-development
    max_concurrent: 1

  # Frontend developer
  frontend-developer:
    role: Frontend Developer
    model: claude-3-sonnet
    capabilities:
      - react
      - vue
      - svelte
      - web-components
    max_concurrent: 1

  # DevOps engineer
  devops-engineer:
    role: DevOps Engineer
    model: claude-3-sonnet
    capabilities:
      - deployment
      - docker
      - serverless
      - edge-computing
    max_concurrent: 1
{{/if}}

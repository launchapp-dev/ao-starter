# AO Bun Phases Configuration
# Generated by ao-starter for Bun projects
# Generated: {{timestamp}}

phases:
{{#if phases}}
{{#each phases}}
  {{@key}}:
    agent: {{this.agent}}
    description: {{this.description}}
    timeout_secs: {{this.timeout_secs}}
{{#if this.outputs}}
    outputs:
{{#each this.outputs}}
      - {{this}}
{{/each}}
{{/if}}
{{#if this.depends_on}}
    depends_on:
{{#each this.depends_on}}
      - {{this}}
{{/each}}
{{/if}}
{{/each}}
{{else}}
  # Dependency setup
  dependency-setup:
    agent: js-developer
    description: Install dependencies with Bun
    timeout_secs: 300
    outputs:
      - bun-lockb
      - dependencies
      - workspace-config

  # Implementation
  implementation:
    agent: js-developer
    description: Implement JavaScript/TypeScript code
    timeout_secs: 1800
    outputs:
      - source-code
      - unit-tests
    depends_on:
      - dependency-setup

  # Type checking
  type-checking:
    agent: js-developer
    description: Run TypeScript type checking
    timeout_secs: 600
    outputs:
      - type-check-results
      - type-definitions
    depends_on:
      - implementation

  # Linting
  linting:
    agent: js-developer
    description: Run ESLint and Prettier
    timeout_secs: 300
    outputs:
      - lint-results
      - formatted-code
    depends_on:
      - implementation

  # Testing
  testing:
    agent: devops-engineer
    description: Run tests with Bun test runner
    timeout_secs: 900
    outputs:
      - test-results
      - coverage-report
    depends_on:
      - implementation

  # Bundling
  bundling:
    agent: ui-developer
    description: Bundle application for production
    timeout_secs: 600
    outputs:
      - bundle
      - assets
    depends_on:
      - testing
{{/if}}

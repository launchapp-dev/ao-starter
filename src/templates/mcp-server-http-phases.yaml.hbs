# AO MCP HTTP Server Phases Configuration
# Generated by ao-starter for MCP HTTP server projects
# Generated: {{timestamp}}

phases:
{{#if phases}}
{{#each phases}}
  {{@key}}:
    agent: {{this.agent}}
    description: {{this.description}}
    timeout_secs: {{this.timeout_secs}}
{{#if this.outputs}}
    outputs:
{{#each this.outputs}}
      - {{this}}
{{/each}}
{{/if}}
{{#if this.depends_on}}
    depends_on:
{{#each this.depends_on}}
      - {{this}}
{{/each}}
{{/if}}
{{/each}}
{{else}}
  # Design MCP tool/resource/prompt contracts before implementation
  tool-design:
    agent: mcp-implementer
    description: Design MCP tool, resource, and prompt schemas with Zod definitions
    timeout_secs: 600
    outputs:
      - tool-schema-definitions
      - resource-uri-patterns
      - prompt-argument-specs

  # Configure HTTP transport (StreamableHTTP or SSE)
  transport-setup:
    agent: transport-engineer
    description: Set up HTTP transport layer with session management and CORS
    timeout_secs: 600
    outputs:
      - http-server-config
      - transport-handler
      - session-manager
    depends_on:
      - tool-design

  # Implement tools, resources, and prompts
  implementation:
    agent: mcp-implementer
    description: Implement MCP tools, resources, and prompts with full type safety
    timeout_secs: 1800
    outputs:
      - tool-handlers
      - resource-handlers
      - prompt-handlers
    depends_on:
      - transport-setup

  # Type-check all TypeScript
  type-checking:
    agent: type-safety-engineer
    description: Run tsc --noEmit and fix all type errors
    timeout_secs: 300
    outputs:
      - type-check-results
    depends_on:
      - implementation

  # Validate tool input/output schemas and error handling
  tool-validation:
    agent: quality-engineer
    description: Validate tool schemas, test error paths, and verify MCP protocol compliance
    timeout_secs: 900
    outputs:
      - schema-validation-report
      - error-handling-coverage
      - protocol-compliance-check
    depends_on:
      - implementation

  # Integration test via MCP Inspector or direct HTTP calls
  integration-testing:
    agent: quality-engineer
    description: Run integration tests against the live HTTP server
    timeout_secs: 900
    outputs:
      - integration-test-results
      - transport-connectivity-check
    depends_on:
      - type-checking
      - tool-validation

  # Generate tool reference documentation
  documentation:
    agent: mcp-implementer
    description: Document all tools, resources, and prompts with usage examples
    timeout_secs: 600
    outputs:
      - tool-reference-docs
      - transport-setup-guide
      - claude-desktop-config-snippet
    depends_on:
      - integration-testing
{{/if}}

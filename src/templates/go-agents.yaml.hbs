# AO Go Agents Configuration
# Generated by ao-starter for Go projects
# Generated: {{timestamp}}

agents:
{{#if agents}}
{{#each agents}}
  {{@key}}:
    role: {{this.role}}
    model: {{this.model}}
{{#if this.capabilities}}
    capabilities:
{{#each this.capabilities}}
      - {{this}}
{{/each}}
{{/if}}
    max_concurrent: {{this.max_concurrent}}
{{/each}}
{{else}}
  # Go backend developer
  go-developer:
    role: Go Backend Developer
    model: claude-3-opus
    capabilities:
      - go-development
      - concurrency-patterns
      - api-design
      - microservices
    max_concurrent: 1

  # CLI tool developer
  cli-developer:
    role: CLI Tool Developer
    model: claude-3-sonnet
    capabilities:
      - command-line-tools
      - flag-parsing
      - terminal-ui
    max_concurrent: 1

  # DevOps engineer
  devops-engineer:
    role: DevOps Engineer
    model: claude-3-sonnet
    capabilities:
      - docker
      - kubernetes
      - ci-cd
      - deployment
    max_concurrent: 1
{{/if}}

# AO Deno Phases Configuration
# Generated by ao-starter for Deno projects
# Generated: {{timestamp}}

phases:
{{#if phases}}
{{#each phases}}
  {{@key}}:
    agent: {{this.agent}}
    description: {{this.description}}
    timeout_secs: {{this.timeout_secs}}
{{#if this.outputs}}
    outputs:
{{#each this.outputs}}
      - {{this}}
{{/each}}
{{/if}}
{{#if this.depends_on}}
    depends_on:
{{#each this.depends_on}}
      - {{this}}
{{/each}}
{{/if}}
{{/each}}
{{else}}
  # Dependency setup
  dependency-setup:
    agent: deno-developer
    description: Initialize Deno dependencies
    timeout_secs: 300
    outputs:
      - deno-json
      - lock-file
      - dependencies

  # Implementation
  implementation:
    agent: deno-developer
    description: Implement TypeScript code
    timeout_secs: 1800
    outputs:
      - source-code
      - unit-tests
    depends_on:
      - dependency-setup

  # Type checking
  type-checking:
    agent: deno-developer
    description: Run Deno type checking
    timeout_secs: 600
    outputs:
      - type-check-results
    depends_on:
      - implementation

  # Linting
  linting:
    agent: deno-developer
    description: Run Deno linter
    timeout_secs: 300
    outputs:
      - lint-results
      - deno-fmt
    depends_on:
      - implementation

  # Testing
  testing:
    agent: devops-engineer
    description: Run Deno tests
    timeout_secs: 900
    outputs:
      - test-results
      - coverage-report
    depends_on:
      - implementation

  # Documentation
  documentation:
    agent: deno-developer
    description: Generate documentation
    timeout_secs: 600
    outputs:
      - docs
      - api-reference
    depends_on:
      - implementation

  # Deployment preparation
  deployment-prep:
    agent: devops-engineer
    description: Prepare for deployment
    timeout_secs: 600
    outputs:
      - deploy-artifacts
      - dockerfile
    depends_on:
      - testing
{{/if}}

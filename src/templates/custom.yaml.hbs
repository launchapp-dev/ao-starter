# AO Custom Configuration
# Generated by ao-starter
# Project Type: {{projectType}}
# Generated: {{timestamp}}

# Custom settings for your project
custom:
  project_type: {{projectType}}
{{#if projectName}}
  project_name: {{projectName}}
{{/if}}
  
  # Scheduling configuration
  scheduling:
{{#if schedules}}
{{#each schedules}}
    {{name}}:
{{#if this.interval_secs}}
      interval_secs: {{this.interval_secs}}
{{/if}}
{{#if this.auto_run_ready}}
      auto_run_ready: {{this.auto_run_ready}}
{{/if}}
{{#if this.auto_merge}}
      auto_merge: {{this.auto_merge}}
{{/if}}
{{#if this.auto_pr}}
      auto_pr: {{this.auto_pr}}
{{/if}}
{{/each}}
{{else}}
    # Run daemon every 30 seconds
    interval_secs: 30
    
    # Auto-run ready tasks
    auto_run_ready: true
    
    # Auto-merge completed PRs
    auto_merge: false
    
    # Auto-create PRs for completed work
    auto_pr: true
{{/if}}

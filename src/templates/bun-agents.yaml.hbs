# AO Bun Agents Configuration
# Generated by ao-starter for Bun projects
# Generated: {{timestamp}}

agents:
{{#if agents}}
{{#each agents}}
  {{@key}}:
    role: {{this.role}}
    model: {{this.model}}
{{#if this.capabilities}}
    capabilities:
{{#each this.capabilities}}
      - {{this}}
{{/each}}
{{/if}}
    max_concurrent: {{this.max_concurrent}}
{{/each}}
{{else}}
  # Full-stack JavaScript developer
  js-developer:
    role: JavaScript Developer
    model: claude-3-opus
    capabilities:
      - javascript-development
      - typescript
      - bun-runtime
      - node-api-compatibility
    max_concurrent: 1

  # UI developer
  ui-developer:
    role: UI Developer
    model: claude-3-sonnet
    capabilities:
      - react
      - vite
      - styling
      - component-development
    max_concurrent: 1

  # DevOps engineer
  devops-engineer:
    role: DevOps Engineer
    model: claude-3-sonnet
    capabilities:
      - deployment
      - bundling
      - serverless
      - docker
    max_concurrent: 1
{{/if}}

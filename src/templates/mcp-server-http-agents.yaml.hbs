# AO MCP HTTP Server Agents Configuration
# Generated by ao-starter for MCP HTTP server projects
# Generated: {{timestamp}}

agents:
{{#if agents}}
{{#each agents}}
  {{@key}}:
    role: {{this.role}}
    model: {{this.model}}
{{#if this.capabilities}}
    capabilities:
{{#each this.capabilities}}
      - {{this}}
{{/each}}
{{/if}}
    max_concurrent: {{this.max_concurrent}}
{{/each}}
{{else}}
  # MCP protocol implementer — designs and implements tools, resources, and prompts
  mcp-implementer:
    role: MCP Protocol Implementer
    model: claude-sonnet-4-6
    capabilities:
      - mcp-tool-design
      - mcp-resource-design
      - mcp-prompt-design
      - typescript-development
      - http-transport-setup
    max_concurrent: 1

  # HTTP transport engineer — configures StreamableHTTP / SSE transport layer
  transport-engineer:
    role: HTTP Transport Engineer
    model: claude-sonnet-4-6
    capabilities:
      - streamable-http-transport
      - sse-transport
      - express-server-setup
      - cors-configuration
      - session-management
    max_concurrent: 1

  # Quality engineer — validates tool schemas, input/output contracts, error handling
  quality-engineer:
    role: MCP Quality Engineer
    model: claude-sonnet-4-6
    capabilities:
      - tool-schema-validation
      - zod-schema-authoring
      - integration-testing
      - error-boundary-testing
      - mcp-inspector-usage
    max_concurrent: 1

  # Type safety engineer — keeps TypeScript types and Zod schemas aligned
  type-safety-engineer:
    role: Type Safety Engineer
    model: claude-haiku-4-5
    capabilities:
      - type-checking
      - strict-mode
      - zod-schema-authoring
      - declaration-files
    max_concurrent: 1
{{/if}}

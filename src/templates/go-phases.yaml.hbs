# AO Go Phases Configuration
# Generated by ao-starter for Go projects
# Generated: {{timestamp}}

phases:
{{#if phases}}
{{#each phases}}
  {{@key}}:
    agent: {{this.agent}}
    description: {{this.description}}
    timeout_secs: {{this.timeout_secs}}
{{#if this.outputs}}
    outputs:
{{#each this.outputs}}
      - {{this}}
{{/each}}
{{/if}}
{{#if this.depends_on}}
    depends_on:
{{#each this.depends_on}}
      - {{this}}
{{/each}}
{{/if}}
{{/each}}
{{else}}
  # Module initialization
  module-init:
    agent: go-developer
    description: Initialize Go module and dependencies
    timeout_secs: 300
    outputs:
      - go-mod
      - dependencies
      - module-structure

  # Implementation
  implementation:
    agent: go-developer
    description: Implement Go code
    timeout_secs: 1800
    outputs:
      - go-code
      - unit-tests
    depends_on:
      - module-init

  # Vet and lint
  vet-check:
    agent: go-developer
    description: Run go vet and static analysis
    timeout_secs: 300
    outputs:
      - vet-results
      - static-analysis
    depends_on:
      - implementation

  # Formatting
  formatting:
    agent: go-developer
    description: Run gofmt and ensure code style
    timeout_secs: 300
    outputs:
      - formatted-code
      - style-check
    depends_on:
      - implementation

  # Testing
  testing:
    agent: devops-engineer
    description: Run tests with coverage
    timeout_secs: 900
    outputs:
      - test-results
      - coverage-report
    depends_on:
      - implementation

  # Documentation
  documentation:
    agent: go-developer
    description: Generate and verify documentation
    timeout_secs: 600
    outputs:
      - godoc
      - package-docs
    depends_on:
      - implementation

  # Benchmarking
  benchmarking:
    agent: go-developer
    description: Run benchmarks and compare performance
    timeout_secs: 600
    outputs:
      - benchmark-results
      - performance-report
    depends_on:
      - testing
{{/if}}

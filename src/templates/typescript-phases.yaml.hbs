# AO TypeScript Phases Configuration
# Generated by ao-starter for TypeScript projects
# Generated: {{timestamp}}

phases:
{{#if phases}}
{{#each phases}}
  {{@key}}:
    agent: {{this.agent}}
    description: {{this.description}}
    timeout_secs: {{this.timeout_secs}}
{{#if this.outputs}}
    outputs:
{{#each this.outputs}}
      - {{this}}
{{/each}}
{{/if}}
{{#if this.depends_on}}
    depends_on:
{{#each this.depends_on}}
      - {{this}}
{{/each}}
{{/if}}
{{/each}}
{{else}}
  # Environment setup
  env-setup:
    agent: ts-developer
    description: Set up TypeScript development environment
    timeout_secs: 300
    outputs:
      - tsconfig-configuration
      - node-modules
      - type-definitions

  # Type definitions planning
  type-planning:
    agent: type-safety-engineer
    description: Design type definitions and interfaces
    timeout_secs: 600
    outputs:
      - type-hierarchy
      - interface-definitions
      - generic-type-design
    depends_on:
      - env-setup

  # Code implementation
  implementation:
    agent: ts-developer
    description: Implement TypeScript code with type safety
    timeout_secs: 1800
    outputs:
      - typescript-code
      - unit-tests
    depends_on:
      - type-planning

  # Type checking
  type-checking:
    agent: type-safety-engineer
    description: Run TypeScript compiler and fix type errors
    timeout_secs: 600
    outputs:
      - type-check-results
      - type-corrections
    depends_on:
      - implementation

  # Linting and formatting
  linting:
    agent: ts-developer
    description: Run ESLint and Prettier
    timeout_secs: 300
    outputs:
      - lint-results
      - formatted-code
    depends_on:
      - implementation

  # Unit testing
  unit-testing:
    agent: ts-developer
    description: Run Jest tests with coverage
    timeout_secs: 600
    outputs:
      - test-results
      - coverage-report
    depends_on:
      - implementation

  # Integration testing
  integration-testing:
    agent: backend-developer
    description: Run integration tests
    timeout_secs: 900
    outputs:
      - integration-test-results
      - api-test-results
    depends_on:
      - type-checking
      - linting

  # Documentation
  documentation:
    agent: ts-developer
    description: Generate TypeDoc API documentation
    timeout_secs: 600
    outputs:
      - api-documentation
      - type-documentation
    depends_on:
      - implementation
{{/if}}

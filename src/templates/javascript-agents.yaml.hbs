# AO JavaScript Agents Configuration
# Generated by ao-starter for JavaScript projects
# Generated: {{timestamp}}

agents:
{{#if agents}}
{{#each agents}}
  {{@key}}:
    role: {{this.role}}
    model: {{this.model}}
{{#if this.capabilities}}
    capabilities:
{{#each this.capabilities}}
      - {{this}}
{{/each}}
{{/if}}
    max_concurrent: {{this.max_concurrent}}
{{/each}}
{{else}}
  # JavaScript developer
  js-developer:
    role: JavaScript Developer
    model: claude-3-opus
    capabilities:
      - javascript-development
      - dom-manipulation
      - es6-plus-features
      - npm-package-development
    max_concurrent: 1

  # Frontend engineer
  frontend-engineer:
    role: Frontend Engineer
    model: claude-3-sonnet
    capabilities:
      - responsive-design
      - css-animation
      - browser-apis
      - progressive-web-apps
    max_concurrent: 1

  # Node.js backend developer
  node-developer:
    role: Node.js Backend Developer
    model: claude-3-sonnet
    capabilities:
      - nodejs-development
      - express-rest-apis
      - middleware-development
      - server-deployment
    max_concurrent: 1

  # Quality assurance engineer
  qa-engineer:
    role: QA Engineer
    model: claude-3-sonnet
    capabilities:
      - jest-testing
      - cypress-e2e
      - accessibility-testing
      - cross-browser-testing
    max_concurrent: 1
{{/if}}

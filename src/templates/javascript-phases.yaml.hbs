# AO JavaScript Phases Configuration
# Generated by ao-starter for JavaScript projects
# Generated: {{timestamp}}

phases:
{{#if phases}}
{{#each phases}}
  {{@key}}:
    agent: {{this.agent}}
    description: {{this.description}}
    timeout_secs: {{this.timeout_secs}}
{{#if this.outputs}}
    outputs:
{{#each this.outputs}}
      - {{this}}
{{/each}}
{{/if}}
{{#if this.depends_on}}
    depends_on:
{{#each this.depends_on}}
      - {{this}}
{{/each}}
{{/if}}
{{/each}}
{{else}}
  # Environment setup
  env-setup:
    agent: js-developer
    description: Set up JavaScript development environment
    timeout_secs: 300
    outputs:
      - node-modules
      - package-configuration
      - git-hooks

  # Code implementation
  implementation:
    agent: js-developer
    description: Implement JavaScript code
    timeout_secs: 1800
    outputs:
      - javascript-code
      - unit-tests
    depends_on:
      - env-setup

  # Linting and formatting
  linting:
    agent: js-developer
    description: Run ESLint and Prettier
    timeout_secs: 300
    outputs:
      - lint-results
      - formatted-code
    depends_on:
      - implementation

  # Unit testing
  unit-testing:
    agent: qa-engineer
    description: Run Jest unit tests
    timeout_secs: 600
    outputs:
      - test-results
      - coverage-report
    depends_on:
      - implementation

  # E2E testing
  e2e-testing:
    agent: qa-engineer
    description: Run Cypress end-to-end tests
    timeout_secs: 900
    outputs:
      - e2e-test-results
      - browser-compatibility-report
    depends_on:
      - linting
      - unit-testing

  # Bundle optimization
  bundle-optimization:
    agent: frontend-engineer
    description: Optimize JavaScript bundles
    timeout_secs: 600
    outputs:
      - optimized-bundles
      - bundle-analysis
    depends_on:
      - linting

  # Documentation
  documentation:
    agent: js-developer
    description: Generate JSDoc and README documentation
    timeout_secs: 600
    outputs:
      - api-documentation
      - usage-examples
    depends_on:
      - implementation
{{/if}}

# AO TypeScript Agents Configuration
# Generated by ao-starter for TypeScript projects
# Generated: {{timestamp}}

agents:
{{#if agents}}
{{#each agents}}
  {{@key}}:
    role: {{this.role}}
    model: {{this.model}}
{{#if this.capabilities}}
    capabilities:
{{#each this.capabilities}}
      - {{this}}
{{/each}}
{{/if}}
    max_concurrent: {{this.max_concurrent}}
{{/each}}
{{else}}
  # TypeScript developer
  ts-developer:
    role: TypeScript Developer
    model: claude-3-opus
    capabilities:
      - typescript-development
      - type-system-mastery
      - generic-programming
      - decorator-usage
    max_concurrent: 1

  # Frontend engineer
  frontend-engineer:
    role: Frontend Engineer
    model: claude-3-sonnet
    capabilities:
      - react-development
      - component-architecture
      - state-management
      - styled-components
    max_concurrent: 1

  # Node.js backend developer
  backend-developer:
    role: Node.js Backend Developer
    model: claude-3-sonnet
    capabilities:
      - express-rest-apis
      - database-integration
      - authentication
      - api-design
    max_concurrent: 1

  # Type safety engineer
  type-safety-engineer:
    role: Type Safety Engineer
    model: claude-3-sonnet
    capabilities:
      - type-checking
      - strict-mode
      - type-guard-implementation
      - declaration-files
    max_concurrent: 1
{{/if}}

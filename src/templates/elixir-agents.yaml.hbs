# AO Elixir Agents Configuration
# Generated by ao-starter for Elixir projects
# Generated: {{timestamp}}

agents:
{{#if agents}}
{{#each agents}}
  {{@key}}:
    role: {{this.role}}
    model: {{this.model}}
{{#if this.capabilities}}
    capabilities:
{{#each this.capabilities}}
      - {{this}}
{{/each}}
{{/if}}
    max_concurrent: {{this.max_concurrent}}
{{/each}}
{{else}}
  # Elixir backend developer
  elixir-developer:
    role: Elixir Backend Developer
    model: claude-3-opus
    capabilities:
      - elixir-development
      - functional-programming
      - concurrency
      -OTP
    max_concurrent: 1

  # Phoenix web developer
  phoenix-developer:
    role: Phoenix Web Developer
    model: claude-3-sonnet
    capabilities:
      - phoenix-framework
      - ecto
      - liveview
      - channels
    max_concurrent: 1

  # DevOps engineer
  devops-engineer:
    role: DevOps Engineer
    model: claude-3-sonnet
    capabilities:
      - deployment
      - mix-tasks
      - docker
      - releases
    max_concurrent: 1
{{/if}}

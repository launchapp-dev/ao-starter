# AO Elixir Phases Configuration
# Generated by ao-starter for Elixir projects
# Generated: {{timestamp}}

phases:
{{#if phases}}
{{#each phases}}
  {{@key}}:
    agent: {{this.agent}}
    description: {{this.description}}
    timeout_secs: {{this.timeout_secs}}
{{#if this.outputs}}
    outputs:
{{#each this.outputs}}
      - {{this}}
{{/each}}
{{/if}}
{{#if this.depends_on}}
    depends_on:
{{#each this.depends_on}}
      - {{this}}
{{/each}}
{{/if}}
{{/each}}
{{else}}
  # Mix project setup
  mix-setup:
    agent: elixir-developer
    description: Initialize Mix project and dependencies
    timeout_secs: 300
    outputs:
      - mix-exs
      - dependencies
      - application-structure

  # Core implementation
  implementation:
    agent: elixir-developer
    description: Implement Elixir code
    timeout_secs: 1800
    outputs:
      - elixir-code
      - unit-tests
    depends_on:
      - mix-setup

  # Testing
  testing:
    agent: elixir-developer
    description: Run ExUnit tests
    timeout_secs: 900
    outputs:
      - test-results
      - coverage-report
    depends_on:
      - implementation

  # Credo linting
  linting:
    agent: elixir-developer
    description: Run Credo analysis
    timeout_secs: 600
    outputs:
      - credo-results
      - style-issues
    depends_on:
      - implementation

  # Documentation
  documentation:
    agent: phoenix-developer
    description: Generate ExDoc documentation
    timeout_secs: 600
    outputs:
      - exdoc
      - api-reference
    depends_on:
      - implementation

  # Release preparation
  release-prep:
    agent: devops-engineer
    description: Prepare application for release
    timeout_secs: 600
    outputs:
      - releases
      - distillery-config
      - docker-image
    depends_on:
      - testing
{{/if}}
